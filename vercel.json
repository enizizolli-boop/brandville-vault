{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "crons": [
    {
      "path": "/api/cron-odoo-status",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron-zoho-sync",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron-odoo-bags-sync",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron-odoo-full-sync",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "api/odoo-sync.js": { "maxDuration": 60 },
    "api/odoo-bags-sync.js": { "maxDuration": 60 },
    "api/cron-zoho-sync.js": { "maxDuration": 60 },
    "api/cron-odoo-status.js": { "maxDuration": 60 },
    "api/cron-odoo-bags-sync.js": { "maxDuration": 60 },
    "api/cron-odoo-full-sync.js": { "maxDuration": 300 },
    "api/zoho-webhook.js": { "maxDuration": 300 }
  }
}
